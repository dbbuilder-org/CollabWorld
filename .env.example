# =============================================================================
# Collab World — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local
# See docs/SETUP.md for where to get each value.
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================================
# Database (PostgreSQL via Prisma)
# Local: start with `docker compose up -d`
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collabworld"

# =============================================================================
# Clerk — Authentication
# https://dashboard.clerk.com → Create application
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs (keep as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# =============================================================================
# Mux — Video Upload & Streaming
# https://dashboard.mux.com → Settings → API Access Tokens
# =============================================================================
MUX_TOKEN_ID=...
MUX_TOKEN_SECRET=...
MUX_WEBHOOK_SECRET=...

# =============================================================================
# Resend — Transactional Email
# https://resend.com → API Keys
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Collab World <hello@collabworld.io>"

# =============================================================================
# Stripe — Payments & Subscriptions
# https://dashboard.stripe.com → Developers → API Keys
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PREMIUM_PRICE_ID=price_...

# =============================================================================
# Upstash Redis — Leaderboard Cache & Background Jobs
# https://console.upstash.com → Create Database → REST API
# =============================================================================
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# =============================================================================
# Cloudflare R2 — Static Asset Storage (contest packs, thumbnails)
# https://dash.cloudflare.com → R2 → Create bucket
# =============================================================================
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=collabworld-assets
R2_PUBLIC_URL=https://assets.collabworld.io
